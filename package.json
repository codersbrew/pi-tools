{
  "name": "@codersbrew/pi-tools",
  "version": "0.1.0",
  "description": "A pi package bundling CodersBrew pi extensions.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "coding-agent",
    "codersbrew"
  ],
  "license": "MIT",
  "author": "CodersBrew",
  "homepage": "https://github.com/codersbrew/pi-tools#readme",
  "bugs": {
    "url": "https://github.com/codersbrew/pi-tools/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codersbrew/pi-tools.git"
  },
  "files": [
    "extensions",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "pack:check": "npm pack --dry-run",
    "check": "npm run typecheck && npm run pack:check"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.60.0",
    "@mariozechner/pi-tui": "^0.60.0",
    "@types/node": "^24.3.0",
    "typescript": "^5.7.3"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  }
}
